# ─────────────────────────────────────────────────────────────
# MonPrestataire — Variables d'environnement de PRODUCTION
# Copiez ce fichier en .env sur Vercel (Settings → Environment Variables)
# ─────────────────────────────────────────────────────────────

# Base de données PostgreSQL (Neon recommandé — neon.tech gratuit jusqu'à 500Mo)
# 1. Créer un projet sur neon.tech
# 2. Copier la connection string "pooled" pour DATABASE_URL
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="https://mon-prestataire.fr"
NEXTAUTH_SECRET="REMPLACER-par-openssl-rand-base64-32"

# Stripe (mode LIVE — dashboard.stripe.com → API Keys)
# Après déploiement : lancer `npm run stripe:setup` avec la clé live pour créer les prix
STRIPE_PUBLIC_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."    # Stripe Dashboard → Webhooks → endpoint secret
STRIPE_STANDARD_MONTHLY_PRICE_ID="price_..."    # générés par npm run stripe:setup
STRIPE_STANDARD_YEARLY_PRICE_ID="price_..."
STRIPE_PREMIUM_MONTHLY_PRICE_ID="price_..."
STRIPE_PREMIUM_YEARLY_PRICE_ID="price_..."

# Emails transactionnels (resend.com — gratuit 3000 emails/mois)
RESEND_API_KEY="re_..."
EMAIL_FROM="MonPrestataire <noreply@mon-prestataire.fr>"

# Stockage photos/vidéos (Vercel Blob — Dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Admin
ADMIN_EMAIL="admin@mon-prestataire.fr"

# Cron sécurité (générer avec : openssl rand -hex 32)
CRON_SECRET="REMPLACER-par-secret-aleatoire-fort"

# Instagram (optionnel)
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""
