# ============================================================
# MonPrestataire — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ============================================================

# Base de données PostgreSQL (Neon recommandé pour Vercel)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="https://mon-prestataire.fr"
NEXTAUTH_SECRET="votre-secret-nextauth-super-fort-32-chars-minimum"

# Stripe
STRIPE_PUBLIC_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STANDARD_MONTHLY_PRICE_ID="price_..."
STRIPE_STANDARD_YEARLY_PRICE_ID="price_..."
STRIPE_PREMIUM_MONTHLY_PRICE_ID="price_..."
STRIPE_PREMIUM_YEARLY_PRICE_ID="price_..."

# Emails (https://resend.com)
RESEND_API_KEY="re_..."
EMAIL_FROM="MonPrestataire <noreply@mon-prestataire.fr>"

# Vercel Blob (photos et vidéos — https://vercel.com/storage/blob)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Cron
CRON_SECRET="votre-secret-cron-fort"

# Admin
ADMIN_EMAIL="admin@mon-prestataire.fr"
